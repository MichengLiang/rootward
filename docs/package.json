{
  "name": "rootward-cli-templates",
  "private": true,
  "version": "0.1.2",
  "license": "Apache-2.0",
  "type": "module",
  "scripts": {
    "test": "node --test",
    "build:adoc": "node scripts/build-adoc.mjs",
    "build:catalog": "asciidoctor catalog.adoc -D build/html",
    "build:index": "node scripts/create-index.mjs",
    "build:books": "node scripts/build-books.mjs",
    "copy:assets": "node scripts/copy-assets.mjs",
    "enhance:html": "node scripts/add-home-links.mjs build/html",
    "check:html": "node scripts/check-html-local-resources.mjs build/html",
    "build": "pnpm run build:adoc && pnpm run build:catalog && pnpm run build:index && pnpm run build:books && pnpm run copy:assets && pnpm run enhance:html && pnpm run check:html"
  },
  "devDependencies": {
    "@asciidoctor/reducer": "1.1.2",
    "asciidoctor": "2.2.9"
  }
}
