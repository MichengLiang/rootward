{
  "id": "rust",
  "language": "rust",
  "status": "implemented",
  "templateRoot": "template",
  "identity": {
    "cliName": {
      "required": true,
      "pattern": "^[a-z][a-z0-9-]*$"
    },
    "configDirName": {
      "derivedFrom": "cliName",
      "format": ".{cliName}"
    },
    "crateName": {
      "required": true,
      "pattern": "^[a-z][a-z0-9_-]*$"
    },
    "binName": {
      "required": true,
      "pattern": "^[a-z][a-z0-9-]*$"
    }
  },
  "tokens": {
    "rootward-token-cli-name": "cliName",
    ".rootward-token-config-dir-name": "configDirName",
    "rootward_token_crate_name": "crateName",
    "rootward-token-bin-name": "binName"
  },
  "exclude": ["target", "temporary"],
  "postcheck": [
    "Cargo.toml",
    "README.md",
    "src/main.rs",
    "src/lib.rs",
    "src/cli.rs",
    "src/core/constants.rs",
    "tests/cli_contract.rs"
  ],
  "nextCommands": [
    "cargo fmt --check",
    "cargo clippy --all-targets --all-features -- -D warnings",
    "cargo test",
    "cargo build"
  ]
}
